# ─── Environment ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ─── Database ──────────────────────────────────────────────────────────────────
# Production: postgresql+asyncpg://user:password@host:5432/price_drift
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/price_drift

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1

# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=200

# ─── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
FIELD_ENCRYPTION_KEY=

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ─── Drift thresholds ──────────────────────────────────────────────────────────
# These are system defaults. Per-client overrides are stored in the clients table.
DEFAULT_DRIFT_TOLERANCE_PCT=0.02
WARNING_THRESHOLD_PCT=0.02
ALERT_THRESHOLD_PCT=0.05
CRITICAL_THRESHOLD_PCT=0.10

# ─── Email alerts ──────────────────────────────────────────────────────────────
ALERT_FROM_EMAIL=alerts@backbone-ai.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Minimum severity that triggers an email: warning | alert | critical
EMAIL_NOTIFICATION_THRESHOLD=alert

# ─── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
