# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=production                        # development | staging | production
SECRET_KEY=change-me-to-64-random-bytes
DEBUG=false

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/po_matching
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096

# ─── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=backbone-ai-documents
KMS_KEY_ID=arn:aws:kms:eu-west-2:...

# ─── Encryption ────────────────────────────────────────────────────────────────
# 32-byte key, base64-encoded. Generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
FIELD_ENCRYPTION_KEY=base64-encoded-32-byte-key

# ─── Auth ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── ERP — Sage 200 Cloud ──────────────────────────────────────────────────────
# Credentials stored encrypted in database after initial setup.
# These are only used during first-time connector registration.
SAGE200_CLIENT_ID=
SAGE200_CLIENT_SECRET=
SAGE200_REDIRECT_URI=https://api.backbone-ai.com/po-matching/v1/connectors/sage200/callback

# ─── ERP — Xero ────────────────────────────────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://api.backbone-ai.com/po-matching/v1/connectors/xero/callback

# ─── Email Ingestion ───────────────────────────────────────────────────────────
# Per-client IMAP credentials are stored encrypted in the database.
# No credentials should be in environment variables for multi-tenant email.

# ─── Alerting ──────────────────────────────────────────────────────────────────
SENTRY_DSN=
ALERT_FROM_EMAIL=alerts@backbone-ai.com

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
API_RATE_LIMIT_PER_MINUTE=1000
