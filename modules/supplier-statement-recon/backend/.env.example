# ─── Environment ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/statement_recon

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/2

# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=512

# ─── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
FIELD_ENCRYPTION_KEY=

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ─── Reconciliation matching ───────────────────────────────────────────────────
# Amount tolerance in GBP (0.01 = 1p — treat amounts within 1p as the same)
AMOUNT_TOLERANCE_GBP=0.01
# Date tolerance in days for matching transactions by date
DATE_TOLERANCE_DAYS=7
# Fuzzy match threshold for reference number matching (0–100)
REFERENCE_FUZZY_THRESHOLD=85

# ─── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
